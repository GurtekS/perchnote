# Perchnote — optional build-time OAuth credentials.
#
# Copy this file to `.env` (or export the variables) BEFORE running
# `npm run tauri:build` to bake Google/Microsoft client IDs into the
# release binary. If you skip this, users will be prompted to enter
# their own client IDs from the in-app Settings → Calendar pane.
#
# These values are read at compile time via Rust's `option_env!()`.
# They never appear in the repository, and they are not read at runtime
# from a `.env` file — the build system reads the process environment.
#
# Where to get them:
#   - Google:    https://console.cloud.google.com/apis/credentials
#                  (create an OAuth 2.0 Client ID, type "Desktop app",
#                   add http://localhost as a redirect URI)
#   - Microsoft: https://portal.azure.com/  →  App registrations
#                  (create a new app, add http://localhost/callback
#                   as a redirect URI, generate a client secret)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# The Anthropic API key used for note generation, chat, and speaker
# diarization is NOT a build-time secret — users paste their own key at
# runtime via Settings → AI. It's stored in the macOS Keychain under
# `com.perchnote.app / anthropic_api_key`.
